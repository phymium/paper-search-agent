# ── Search Topics ────────────────────────────────────────────────────────────
# Comma-separated list of research topics to monitor daily
SEARCH_TOPICS=Tumor metabolism,Tumor microenvironment,Spatial Transcriptomic,multi-omic,medical agents,AI in medicine

# ── LLM Configuration ────────────────────────────────────────────────────────
# Set LLM_MODE to: 'lmstudio', 'openai', or 'deepseek'
LLM_MODE=lmstudio

# LM Studio (local) — leave blank if using OpenAI
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=llama-3-8b-instruct

# OpenAI API — leave blank if using LM Studio or DeepSeek
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# DeepSeek API — leave blank if using LM Studio or OpenAI
# Models: deepseek-chat (V3), deepseek-reasoner (R1)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat

# ── PubMed ───────────────────────────────────────────────────────────────────
# Your email address (required by NCBI for API access)
PUBMED_EMAIL=your@email.com
# Optional: NCBI API key — raises rate limit from 3 to 10 req/sec
# Get one free at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# ── Obsidian Vault Paths ─────────────────────────────────────────────────────
# Folder where the daily digest .md will be saved
OBSIDIAN_VAULT_PATH=/path/to/your/vault/Daily Papers

# Folder where individual high-score (4-5) paper notes will be saved
OBSIDIAN_PAPERS_PATH=/path/to/your/vault/Papers

# ── Optional Tuning ──────────────────────────────────────────────────────────
# Maximum papers to fetch per topic per source (default: 20)
MAX_RESULTS_PER_TOPIC=20

# Importance score threshold for generating individual paper notes (default: 4)
DEEP_DIVE_THRESHOLD=4
